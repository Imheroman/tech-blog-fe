# 이 파일은 필요한 환경변수의 "이름"만 보여주는 예시입니다.
# 실제 값이 담긴 .env / .env.local 은 절대 커밋하지 마세요 (.gitignore 처리됨).
# 사용할 때 이 파일을 복사해 .env.local 로 만들고 값을 채우세요:
#   cp .env.example .env.local
#
# 현재 이 블로그는 정적 사이트라 필수 환경변수가 없습니다.
# 아래는 앞으로 기능을 붙일 때 자주 쓰는 항목 예시입니다. (필요할 때 주석 해제)

# 사이트 기본 URL (사이트맵/RSS/메타태그 등에 사용)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 측정 ID (공개돼도 되는 값)
# NEXT_PUBLIC_GA_ID=

# --- 아래는 백엔드(조회수/댓글 등) 연동 시. 절대 공개 금지, 값은 배포 플랫폼에만 등록 ---
# DATABASE_URL=
# JWT_SECRET=
