# 이 파일은 필요한 환경변수의 "이름"만 보여주는 예시입니다.
# 실제 값이 담긴 .env / .env.local 은 절대 커밋하지 마세요 (.gitignore 처리됨).
# 사용할 때 이 파일을 복사해 .env.local 로 만들고 값을 채우세요:
#   cp .env.example .env.local

# 사이트 기본 URL (사이트맵/RSS/메타태그 등에 사용)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 측정 ID (공개돼도 되는 값)
# NEXT_PUBLIC_GA_ID=

# --- MSW API 모킹 ---

# 로컬 API 모킹 (브라우저 노출). MSW 켜려면 enabled
NEXT_PUBLIC_API_MOCKING=disabled

# 인증 어댑터 선택 (서버 전용): mock | real
AUTH_MODE=mock

# iron-session 암호 (서버 전용, 32자 이상) — 실제 값은 .env.local
SESSION_PASSWORD=replace-with-a-strong-32+char-secret-value

# --- 백엔드 연동 (real 모드) ---

# 백엔드 베이스 URL
API_BASE_URL=http://localhost:8080

# --- 아래는 백엔드(조회수/댓글 등) 연동 시. 절대 공개 금지, 값은 배포 플랫폼에만 등록 ---
# DATABASE_URL=
# JWT_SECRET=

# OAuth (실서버 모드에서 사용; mock 모드는 불필요)
GOOGLE_CLIENT_ID=
KAKAO_CLIENT_ID=
